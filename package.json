{
  "name": "c-outline-map",
  "displayName": "C Outline Map",
  "description": "增强的大纲视图：搜索过滤、键盘导航、快捷键跳转、光标实时跟踪",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/c-outline-map"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "outline",
    "symbol",
    "navigation",
    "c",
    "cpp",
    "c++",
    "c/c++"
  ],
  "qna": "marketplace",
  "icon": "media/icon.png",
  "activationEvents": [
    "onView:c-outline-map.outlineView",
    "onCommand:c-outline-map.focusSearch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "c-outline-map.refresh",
        "title": "C Outline Map: Refresh"
      },
      {
        "command": "c-outline-map.focusSearch",
        "title": "C Outline Map: Focus Search"
      }
    ],
    "keybindings": [
      {
        "command": "c-outline-map.focusSearch",
        "key": "alt+l"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "outline-map",
          "title": "Outline Map",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "outline-map": [
        {
          "type": "webview",
          "id": "c-outline-map.outlineView",
          "name": "Outline Map"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}

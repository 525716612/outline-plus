{
  "name": "outline-plus",
  "displayName": "Outline Plus",
  "description": "增强的大纲视图：搜索过滤、键盘导航、快捷键跳转、光标实时跟踪",
  "version": "1.0.0",
  "publisher": "your-publisher-name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/outline-plus"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "outline",
    "symbol",
    "navigation",
    "c",
    "cpp",
    "c++",
    "c/c++"
  ],
  "qna": "marketplace",
  "activationEvents": [
    "onView:outline-plus.outlineView",
    "onCommand:outline-plus.focusSearch"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "outline-plus.refresh",
        "title": "Outline Plus: Refresh"
      },
      {
        "command": "outline-plus.focusSearch",
        "title": "Outline Plus: Focus Search"
      }
    ],
    "keybindings": [
      {
        "command": "outline-plus.focusSearch",
        "key": "alt+l"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "outline-map",
          "title": "Outline Plus",
          "icon": "$(list-tree)"
        }
      ]
    },
    "views": {
      "outline-map": [
        {
          "type": "webview",
          "id": "outline-plus.outlineView",
          "name": "Outline Plus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.125.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
